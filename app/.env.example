APP_NAME="Layout.ai"
APP_ENV=local
APP_KEY=base64:kDzWwVgCq3LW0U2wvXl2NfX8yzVM6+kuThnecrUCPpc=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8088

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=layoutai
DB_USERNAME=layoutai
DB_PASSWORD=layoutai

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=layoutai

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@layout.ai"
MAIL_FROM_NAME="${APP_NAME}"

# Layout.ai third-party services
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Used only for the combined brand-summary + ad-concepts call (font sizes,
# positions, layout planning). Other Gemini calls keep GEMINI_MODEL.
GEMINI_COMBINED_MODEL=gemini-3.5-flash
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_CRAWL_ENDPOINT=https://api.cloudflare.com/client/v4/accounts/{account}/browser-rendering/crawl
RUNMYPRINT_ENDPOINT=https://www.runmyprint.com/test/image2.php
RENDERER_URL=http://renderer:3000

# Creative scoring (TRIBE v2 on Replicate). Mock provider runs without any
# external service; set provider=replicate + model id to use real TRIBE v2.
CREATIVE_SCORING_PROVIDER=mock
REPLICATE_API_TOKEN=
REPLICATE_TRIBE_MODEL=

# Optional R2/S3 storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
